# =============================================
# BOT-ID — VARIABLES DE ENTORNO
# Copia este archivo como .env y rellena
# tus credenciales reales. NUNCA subas .env a GitHub.
# =============================================

# --- BLUESKY ---
# Tu handle de Bluesky (con o sin .bsky.social)
BLUESKY_USERNAME=tu-usuario.bsky.social

# App Password generado en:
# https://bsky.app/settings/app-passwords
# NO uses tu contraseña principal, crea una dedicada
BLUESKY_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- ANTHROPIC / CLAUDE AI ---
# Obtén tu clave en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- CONFIGURACIÓN OPCIONAL ---
# Máximo de análisis por hora (por defecto: 10)
MAX_ANALYSES_PER_HOUR=10

# Umbral de score para publicar alerta automática (0-100)
BOT_ALERT_THRESHOLD=75

# Handle del bot en Bluesky (para menciones)
BOT_HANDLE=botwatch.bsky.social
